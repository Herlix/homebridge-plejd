{
    "pluginAlias": "Plejd",
    "pluginType": "platform",
    "headerDisplay": "Plejd Setup",
    "footerDisplay": "Either use your login or add devices and crypto key manually. Crypto key and device info is printed as debug logs at startup",
    "singular": true,
    "schema": {
        "username": {
            "title": "Your Plejd email",
            "type": "string",
            "required": false,
            "placeholder": "...",
            "description": "Your Plejd email"
        },
        "password": {
            "title": "Your Plejd password",
            "type": "string",
            "required": false,
            "placeholder": "828291.. or 82-82-91...",
            "description": "With or without '-' "
        },
        "site": {
            "title": "Site",
            "type": "string",
            "required": false,
            "placeholder": "Home",
            "description": "Name of your home that you want to control"
        },
        "crypto_key": {
            "title": "Crypto key",
            "type": "string",
            "required": false,
            "placeholder": "828291.. or 82-82-91...",
            "description": "With or without '-' "
        },
        "transition_ms": {
            "title": "Add transition when changing brightness levels (Note: Not for on/off to reduce flickering with button actions)",
            "type": "number",
            "required": false,
            "placeholder": "1000",
            "description": "Amount of milliseconds of transitioning brightness"
        },
        "motion_reset_seconds": {
            "title": "Motion Reset Timeout (seconds)",
            "type": "number",
            "required": false,
            "placeholder": "75",
            "description": "How long after the last motion event before the sensor resets to 'no motion'. Default: 75 seconds."
        },
        "show_buttons": {
            "title": "Show Buttons",
            "type": "boolean",
            "default": true,
            "required": false,
            "description": "Expose Plejd buttons as HomeKit accessories (single/double/long press). Disable to hide all buttons."
        },
        "double_press_window_ms": {
            "title": "Double Press Window (ms)",
            "type": "number",
            "default": 200,
            "required": false,
            "placeholder": "200",
            "description": "Time window in milliseconds to detect a double press. Increase if double presses are missed."
        },
        "long_press_threshold_ms": {
            "title": "Long Press Threshold (ms)",
            "type": "number",
            "default": 1000,
            "required": false,
            "placeholder": "1000",
            "description": "How long a button must be held in milliseconds before it counts as a long press."
        },
        "hidden_buttons": {
            "title": "Hidden Buttons",
            "type": "array",
            "items": {
                "title": "Button Name",
                "type": "string",
                "placeholder": "Kitchen Button"
            },
            "description": "Button names to hide from HomeKit. Names are logged at startup."
        },
        "devices": {
            "type": "array",
            "items": {
                "title": "Device",
                "type": "object",
                "properties": {
                    "name": {
                        "title": "Name",
                        "type": "string",
                        "placeholder": "Kitchen table",
                        "required": true
                    },
                    "type": {
                        "title": "Type",
                        "type": "string",
                        "oneOf": [
                            { "title": "Light (Dimmable)", "const": "Light" },
                            { "title": "Relay (On/Off only)", "const": "Relay" },
                            { "title": "Sensor (Motion)", "const": "Sensor" }
                        ],
                        "required": true,
                        "description": "Light for dimmable devices, Relay for on/off switches"
                    },
                    "model": {
                        "title": "Model",
                        "type": "string",
                        "enum": [
                            "DIM-01",
                            "DIM-02",
                            "LED-10",
                            "LED-75",
                            "JAL-01",
                            "DIM-01-2P",
                            "REL-01",
                            "REL-02",
                            "REL-01-2P",
                            "DAL-01",
                            "SPR-01",
                            "SPD-01",
                            "CTR-01",
                            "DWN-01",
                            "DWN-02",
                            "CCL-01",
                            "OUT-01",
                            "OUT-02",
                            "LST-01",
                            "WMS-01"
                        ],
                        "required": true
                    },
                    "identifier": {
                        "title": "Identifier",
                        "type": "integer",
                        "placeholder": "11",
                        "required": true
                    },
                    "hidden": {
                        "title": "Hidden",
                        "type": "boolean",
                        "default": false,
                        "required": false
                    }
                }
            }
        }
    }
}
